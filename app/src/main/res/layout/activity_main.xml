<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_marginTop="20dp"
            android:contentDescription="App Logo"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NammaHasiru 🌱"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="40dp"/>

        <Button
            android:id="@+id/add"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="➕ Add Plantation"
            style="@style/GreenButton"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 View My Plants"
            style="@style/GreenButton"
            android:backgroundTint="@color/green"
            android:layout_marginBottom="12dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="true"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/profile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="👤 Profile"
                style="@style/GreenButton"
                android:backgroundTint="#5D4037"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/analytics"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="📊 Analytics"
                style="@style/GreenButton"
                android:backgroundTint="#00796B"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/impact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="🌍 Impact"
                style="@style/GreenButton"
                android:backgroundTint="#0288D1"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/about"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="ℹ️ About"
                style="@style/GreenButton"
                android:backgroundTint="#455A64"
                android:textSize="12sp"/>

        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Together for a greener tomorrow"
            android:layout_marginBottom="20dp"
            android:textColor="@color/green"
            android:alpha="0.7"
            android:textSize="12sp"/>

    </LinearLayout>
</ScrollView>
